{
  "name": "@massdriver/backstage-plugin-common",
  "version": "1.0.4",
  "license": "Apache-2.0",
  "homepage": "https://www.massdriver.cloud/",
  "description": "Shared config schema, annotations, and deep-link builders for the Massdriver Backstage plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/massdriver-cloud/massdriver-backstage",
    "directory": "plugins/massdriver-common"
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "massdriver"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "common-library",
    "pluginId": "massdriver",
    "pluginPackages": [
      "@massdriver/backstage-plugin",
      "@massdriver/backstage-plugin-backend",
      "@massdriver/backstage-plugin-common"
    ]
  },
  "configSchema": "config.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@backstage/config": "^1.3.8"
  },
  "scripts": {
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3"
  },
  "files": [
    "dist",
    "config.d.ts"
  ]
}
